# 设置页KV样式
# 定义设置页的布局和外观

<SettingsScreen>:
    # 页面背景色
    canvas.before:
        Color:
            rgba: 0.95, 0.95, 0.95, 1  # 浅灰色背景
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)

        # 顶部标题栏
        BoxLayout:
            size_hint_y: 0.08
            padding: [dp(10), 0]

            # 返回按钮
            Button:
                text: '← 返回'
                font_name: 'Chinese'
                font_size: dp(16)
                size_hint_x: 0.3
                background_color: 0, 0, 0, 0
                color: 0.13, 0.59, 0.95, 1
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                on_press: root.go_back()

            # 标题
            Label:
                text: '设置'
                font_name: 'Chinese'
                font_size: dp(20)
                color: 0.2, 0.2, 0.2, 1
                bold: True

        # 外观设置分组
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.25
            padding: dp(15)
            spacing: dp(10)

            canvas:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

            Label:
                text: '外观设置'
                font_name: 'Chinese'
                font_size: dp(16)
                color: 0.3, 0.3, 0.3, 1
                bold: True
                halign: 'left'
                text_size: self.size
                size_hint_y: 0.2

            # 默认颜色
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '默认颜色'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Spinner:
                    id: color_spinner
                    text: '灰色'
                    values: ['灰色', '黑色', '纯黑']
                    size_hint_x: 0.4

            # 默认透明度
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '默认透明度'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Slider:
                    id: opacity_slider
                    min: 0
                    max: 100
                    value: 50
                    size_hint_x: 0.5

            # 边框宽度
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '边框宽度'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Spinner:
                    id: border_spinner
                    text: '2px'
                    values: ['1px', '2px', '3px', '4px']
                    size_hint_x: 0.4

        # 行为设置分组
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.25
            padding: dp(15)
            spacing: dp(10)

            canvas:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

            Label:
                text: '行为设置'
                font_name: 'Chinese'
                font_size: dp(16)
                color: 0.3, 0.3, 0.3, 1
                bold: True
                halign: 'left'
                text_size: self.size
                size_hint_y: 0.2

            # 记忆位置
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '记忆位置'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Switch:
                    id: remember_pos
                    active: True
                    size_hint_x: 0.3

            # 记忆大小
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '记忆大小'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Switch:
                    id: remember_size
                    active: True
                    size_hint_x: 0.3

            # 记忆颜色
            BoxLayout:
                size_hint_y: 0.25

                Label:
                    text: '记忆颜色'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Switch:
                    id: remember_color
                    active: True
                    size_hint_x: 0.3

        # 系统信息分组
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.15
            padding: dp(15)
            spacing: dp(5)

            canvas:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

            Label:
                text: '系统信息'
                font_name: 'Chinese'
                font_size: dp(16)
                color: 0.3, 0.3, 0.3, 1
                bold: True
                halign: 'left'
                text_size: self.size
                size_hint_y: 0.3

            # 权限状态
            BoxLayout:
                size_hint_y: 0.35

                Label:
                    text: '权限状态'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.4, 0.4, 0.4, 1
                    halign: 'left'
                    text_size: self.size

                Label:
                    id: permission_status
                    text: '检测中...'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.6, 0.6, 0.6, 1
                    halign: 'right'
                    text_size: self.size

        # 恢复默认按钮
        Button:
            text: '恢复默认设置'
            font_name: 'Chinese'
            font_size: dp(16)
            size_hint_y: 0.08
            background_color: 0.95, 0.95, 0.95, 1
            color: 0.4, 0.4, 0.4, 1

            canvas.before:
                Color:
                    rgba: self.background_color
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]

        # 底部占位
        Widget:
            size_hint_y: 0.04
