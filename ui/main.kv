# 主页KV样式
# 定义主页的布局和外观

<MainScreen>:
    canvas.before:
        Color:
            rgba: 0.96, 0.96, 0.96, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 0
        spacing: 0

        # 顶部蓝色标题栏
        BoxLayout:
            size_hint_y: 0.12
            padding: [dp(20), dp(12)]

            canvas:
                Color:
                    rgba: 0.13, 0.59, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'FloatMask'
                font_size: dp(22)
                color: 1, 1, 1, 1
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'

            Label:
                text: 'v0.1.0'
                font_size: dp(12)
                color: 1, 1, 1, 0.7
                halign: 'right'
                text_size: self.size
                valign: 'middle'

        # 内容区域
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(16)

            # 状态卡片
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.4
                padding: dp(20)
                spacing: dp(12)

                canvas:
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]

                # 状态图标区域
                BoxLayout:
                    size_hint_y: 0.5

                    canvas:
                        # 圆形背景
                        Color:
                            rgba: 0.93, 0.93, 0.93, 1
                        Ellipse:
                            pos: self.center_x - dp(30), self.center_y - dp(30)
                            size: dp(60), dp(60)

                    Label:
                        id: status_icon
                        text: 'FM'
                        font_size: dp(24)
                        color: 0.13, 0.59, 0.95, 1
                        bold: True

                # 状态文字
                Label:
                    id: status_text
                    text: '悬浮窗未激活'
                    font_name: 'Chinese'
                    font_size: dp(18)
                    color: 0.3, 0.3, 0.3, 1
                    bold: True
                    size_hint_y: 0.25

                # 状态描述
                Label:
                    id: status_desc
                    text: '点击下方按钮启动悬浮窗'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    color: 0.6, 0.6, 0.6, 1
                    size_hint_y: 0.25

            # 启动/停止按钮
            Button:
                id: toggle_button
                text: '启动悬浮窗'
                font_name: 'Chinese'
                font_size: dp(17)
                size_hint_y: 0.1
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                bold: True
                on_press: root.toggle_overlay()

                canvas.before:
                    Color:
                        rgba: 0.13, 0.59, 0.95, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            # 功能按钮行
            BoxLayout:
                size_hint_y: 0.08
                spacing: dp(12)

                Button:
                    text: '检测权限'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    background_color: 0, 0, 0, 0
                    color: 0.4, 0.4, 0.4, 1
                    on_press: root.check_permission()

                    canvas.before:
                        Color:
                            rgba: 0.93, 0.93, 0.93, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8)]

                Button:
                    text: '设置'
                    font_name: 'Chinese'
                    font_size: dp(14)
                    background_color: 0, 0, 0, 0
                    color: 0.4, 0.4, 0.4, 1
                    on_press: root.open_settings_page()

                    canvas.before:
                        Color:
                            rgba: 0.93, 0.93, 0.93, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8)]

            # 弹性空间
            Widget:
                size_hint_y: 0.34

            # 底部信息
            Label:
                text: 'Made with Python + Kivy'
                font_size: dp(11)
                color: 0.75, 0.75, 0.75, 1
                size_hint_y: 0.05
