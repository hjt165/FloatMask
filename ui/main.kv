# 主页KV样式

<MainScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32)
        spacing: 0

        Widget:
            size_hint_y: 0.18

        # 状态图标
        Label:
            id: status_icon
            text: 'FM'
            font_size: dp(32)
            color: 0.13, 0.55, 0.95, 1
            bold: True
            size_hint_y: 0.1

        Widget:
            size_hint_y: 0.03

        # 状态
        Label:
            id: status_text
            text: '悬浮窗未激活'
            font_name: 'Chinese'
            font_size: dp(20)
            color: 0.15, 0.15, 0.15, 1
            size_hint_y: 0.07

        # 描述
        Label:
            id: status_desc
            text: '启动后可以在任意应用上方显示遮挡框'
            font_name: 'Chinese'
            font_size: dp(13)
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: 0.05

        Widget:
            size_hint_y: 0.22

        # 启动按钮
        Button:
            id: toggle_button
            text: '启动悬浮窗'
            font_name: 'Chinese'
            font_size: dp(16)
            size_hint_y: 0.07
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_press: root.toggle_overlay()

            canvas.before:
                Color:
                    rgba: 0.13, 0.55, 0.95, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

        Widget:
            size_hint_y: 0.02

        # 底部两个按钮一行
        BoxLayout:
            size_hint_y: 0.06
            spacing: dp(12)

            Button:
                text: '检测权限'
                font_name: 'Chinese'
                font_size: dp(14)
                background_color: 0, 0, 0, 0
                color: 0.5, 0.5, 0.5, 1
                on_press: root.check_permission()

            Button:
                text: '设置'
                font_name: 'Chinese'
                font_size: dp(14)
                background_color: 0, 0, 0, 0
                color: 0.5, 0.5, 0.5, 1
                on_press: root.open_settings_page()

        Widget:
            size_hint_y: 0.27
