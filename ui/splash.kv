# 启动页KV样式

<SplashScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: 0

        Widget:
            size_hint_y: 0.35

        Label:
            text: 'FM'
            font_size: dp(36)
            color: 0.13, 0.55, 0.95, 1
            bold: True
            size_hint_y: 0.1

        Widget:
            size_hint_y: 0.02

        Label:
            text: 'FloatMask'
            font_size: dp(24)
            color: 0.15, 0.15, 0.15, 1
            size_hint_y: 0.08

        Widget:
            size_hint_y: 0.01

        Label:
            text: '字幕遮挡工具'
            font_name: 'Chinese'
            font_size: dp(14)
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: 0.06

        Widget:
            size_hint_y: 0.35

        Label:
            text: 'v0.1.0'
            font_size: dp(12)
            color: 0.75, 0.75, 0.75, 1
            size_hint_y: 0.04
