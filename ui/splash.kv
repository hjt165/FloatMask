# 启动页KV样式
# 定义启动页的布局和外观

<SplashScreen>:
    canvas.before:
        Color:
            rgba: 0.13, 0.59, 0.95, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(16)

        # 弹性空间
        Widget:
            size_hint_y: 0.25

        # 应用图标区域
        BoxLayout:
            size_hint_y: 0.25
            orientation: 'vertical'

            # FM 图标
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.2
                Ellipse:
                    pos: self.center_x - dp(45), self.center_y - dp(45)
                    size: dp(90), dp(90)
                Color:
                    rgba: 1, 1, 1, 1

            Label:
                text: 'FM'
                font_size: dp(36)
                color: 1, 1, 1, 1
                bold: True

        # 应用名称
        Label:
            text: 'FloatMask'
            font_size: dp(30)
            color: 1, 1, 1, 1
            bold: True
            size_hint_y: 0.12

        # 副标题
        Label:
            text: '智能字幕遮挡工具'
            font_name: 'Chinese'
            font_size: dp(16)
            color: 1, 1, 1, 0.8
            size_hint_y: 0.08

        # 状态提示
        Label:
            id: status_label
            text: '正在检测权限...'
            font_name: 'Chinese'
            font_size: dp(13)
            color: 1, 1, 1, 0.6
            size_hint_y: 0.08

        # 弹性空间
        Widget:
            size_hint_y: 0.3

        # 版本号
        Label:
            text: 'v0.1.0'
            font_size: dp(12)
            color: 1, 1, 1, 0.5
            size_hint_y: 0.05
