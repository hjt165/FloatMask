# 启动页KV样式
# 定义启动页的布局和外观

<SplashScreen>:
    # 页面背景色
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # 白色背景
        Rectangle:
            pos: self.pos
            size: self.size
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(50)
        spacing: dp(20)
        
        # 占位空间（顶部）
        Widget:
            size_hint_y: 0.2
        
        # 应用图标区域
        BoxLayout:
            size_hint_y: 0.3
            orientation: 'vertical'
            
            # 图标占位（圆形）
            canvas:
                Color:
                    rgba: 0.13, 0.59, 0.95, 1  # 蓝色 #2196F3
                Ellipse:
                    pos: self.center_x - dp(40), self.center_y - dp(40)
                    size: dp(80), dp(80)
            
            Label:
                text: 'FM'
                font_size: dp(32)
                color: 1, 1, 1, 1
                bold: True
        
        # 应用名称
        Label:
            text: 'FloatMask'
            font_size: dp(32)
            color: 0.2, 0.2, 0.2, 1
            bold: True
            size_hint_y: 0.15
        
        # 副标题
        Label:
            text: '智能字幕遮挡工具'
            font_size: dp(16)
            color: 0.5, 0.5, 0.5, 1
            size_hint_y: 0.1
        
        # 状态提示
        Label:
            id: status_label
            text: '正在检测权限...'
            font_size: dp(14)
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: 0.1
        
        # 占位空间（底部）
        Widget:
            size_hint_y: 0.15
        
        # 版本号
        Label:
            text: 'v0.1.0'
            font_size: dp(12)
            color: 0.7, 0.7, 0.7, 1
            size_hint_y: 0.05
