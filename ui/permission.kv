# 权限引导页KV样式

<PermissionScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(32)
        spacing: 0

        Widget:
            size_hint_y: 0.15

        # 简单的锁图标
        Label:
            text: 'Q'
            font_size: dp(48)
            color: 0.85, 0.85, 0.85, 1
            size_hint_y: 0.12

        Widget:
            size_hint_y: 0.03

        # 标题
        Label:
            text: '需要悬浮窗权限'
            font_name: 'Chinese'
            font_size: dp(20)
            color: 0.15, 0.15, 0.15, 1
            size_hint_y: 0.08

        # 说明
        Label:
            text: '用于在其他应用上层显示遮挡框\n请在设置中开启"显示在其他应用上层"'
            font_name: 'Chinese'
            font_size: dp(14)
            color: 0.55, 0.55, 0.55, 1
            halign: 'center'
            text_size: self.size
            size_hint_y: 0.1

        Widget:
            size_hint_y: 0.2

        # 去设置
        Button:
            text: '去开启权限'
            font_name: 'Chinese'
            font_size: dp(16)
            size_hint_y: 0.07
            background_color: 0.13, 0.55, 0.95, 0
            color: 1, 1, 1, 1
            on_press: root.open_settings()

            canvas.before:
                Color:
                    rgba: 0.13, 0.55, 0.95, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

        Widget:
            size_hint_y: 0.02

        # 返回
        Button:
            text: '返回'
            font_name: 'Chinese'
            font_size: dp(15)
            size_hint_y: 0.06
            background_color: 0, 0, 0, 0
            color: 0.5, 0.5, 0.5, 1
            on_press: root.go_back()

        Widget:
            size_hint_y: 0.25
